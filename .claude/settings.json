{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(node scripts/validate.js*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",
      "Bash(truncate *)",
      "Bash(> index.html*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/validate.js\" 2>&1"
          }
        ]
      }
    ]
  }
}
